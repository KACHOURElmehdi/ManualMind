{
  "manifest_version": 3,
  "name": "Study Assistant (Manual Review)",
  "description": "Manual study and practice assistant for authorized websites. Extracts visible questions and provides suggestions for manual review only.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://example.com/*",
    "https://*.7speaking.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://example.com/*", "https://*.7speaking.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Study Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
